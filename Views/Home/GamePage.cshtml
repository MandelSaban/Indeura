@{
    Game game = ViewBag.gameInfo;
    var images = ViewBag.images;
    bool publi = false;
    if(ViewBag.ImPublisher != null){
      publi = ViewBag.ImPublisher;
    }

    ViewData["Title"] = game.GameName;
}

@{
    var usuarioJson = Context.Session.GetString("usuario"); 
    User usuario = null;
    if (!string.IsNullOrEmpty(usuarioJson))
    {
        usuario = Objeto.StringToObject<User>(usuarioJson);
    }
}

<h1>@game.GameName</h1>   

@if(images != null && images.Count > 0)
{
  <div style="width:600px; margin:auto;">
<div id="carouselExampleIndicators" class="carousel slide" data-bs-ride="carousel">

  <div class="carousel-inner">

    <div class="carousel-item active">
      <img class="d-block w-100" src="~/img/GamePictures/@game.Id/@images[0].image">
    </div>

    @for(int i = 1; i < images.Count; i++)
    {
        <div class="carousel-item">
            <img class="d-block w-100" src="~/img/GamePictures/@game.Id/@images[i].image">
        </div>
    }

  </div>

  <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>

  <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>

</div>
</div>
}
@if(publi){
  <h3>Agregar imagenes</h3>
  <form action="@Url.Action("UploadGameImage","Home")" method="post" enctype="multipart/form-data">
    <input type="file" name="image" accept="image/*" />
    <input type="hidden" name="idGame" value="@game.Id"/>
    <input type="hidden" name="returnUrl" value="@($"/Home/GamePage?gameId={game.Id}")" />
    <button type="submit">Subir</button>
  </form>

  <form action="@Url.Action("UploadGame","Home")" method="post" enctype="multipart/form-data">
    <h5>Nombre del ejecutable (Incluir extension)</h5>
    <input type="text" name="exe" required/>
    <h5>Subir/Actualizar juego</h5>
    <input type="file" name="game" required/>    
    <input type="hidden" name="gameId" value="@game.Id"/>
    <br>
    <button type="submit">Subir</button>
  </form>

  <div>
    <p>Estado del juego: <span id="statusText">Cargando...</span></p>
</div>
}

<br />

@if(!publi){
<pre>@game.Description</pre>
}
else{
  <form method="post" action="@Url.Action("UpdateGameDescription","Home")">
   
        <textarea name="description" rows="10" cols="50">@game.Description</textarea>  
        <input type="hidden" name="returnUrl" value="@($"/Home/GamePage?gameId={game.Id}")"/>
        <input type="hidden" name="gameId" value="@game.Id" />
    <input type="submit" value="Save" />

</form>
}
<p>
    Tags:
    @foreach(var tag in ViewBag.tags)
    {
        <span>@tag </span>
    }
</p>

<p>Created by: <a href='@Url.Action("Profile","Home", new {userId = @game.IdPublisher})'>@ViewBag.creator</a></p>

@if(usuario == null){
  if(game.PriceUSD == 0){
    <a href='@Url.Action("LoginRedirect", "Home", new { returnUrl = "/Home/GamePage?gameId=" + game.Id })'>Añadir a tu biblioteca</a>
  }
  else{
    <a href='@Url.Action("LoginRedirect", "Home", new { returnUrl = "/Home/GamePage?gameId=" + game.Id })'>Comprar por $@game.PriceUSD USD</a>
  }  
}
else if(!ViewBag.IsOwner)
{
  if(game.PriceUSD == 0){
    <a href='@Url.Content("~/Buy/"+game.Id)'>Añadir a tu biblioteca</a>
  }
  else{
    <a href='@Url.Content("~/Buy/"+game.Id)'>Comprar por $@game.PriceUSD USD</a>
  }  
}  
else if (ViewBag.isElectron)
{
    <a href='@Url.Content("~/Download/"+game.Id)'>Instalar juego</a>
    <button onclick="openGame('C:\\Indeura\\Games\\@game.Id')">Abrir juego</button>

    <script>       
    function openGame(folderPath){
        window.electronAPI.send('open-game-folder', folderPath);
    }
    </script>
}
else
{
    <a href='@Url.Content("~/Download/IndeuraSetup.exe")'>Descargar Indeura</a>
}



<br /><br /><br /><br /><br />

<h4>Reviews</h4>
@if(ViewBag.reviews.Count > 0){
  @foreach(Review review in ViewBag.reviews){
  <div style="border: 1px solid black">
    <p>@BD.getNameById(review.IdUser)</p>
    <h5>@TextMods.numberToStars(review.Rating) (@((double)(review.PlaytimeSecondsAtPublish/3600))h)</h5>
    <p>@review.Description</p>
  </div>
}
}
else{
  <h6>Aún no hay nada aquí</h6>
}

@if(usuario!=null){
@if(!BD.GetReviewed(usuario.Id,game.Id)){
  <form method="post" action="@Url.Action("Review","Home")">
  <div class="rating ">
        <input type="radio" name="rate" id="star5" value="5">
    <label for="star5"><i class="fa-solid fa-star"></i></label>

    <input type="radio" name="rate" id="star4" value="4">
    <label for="star4"><i class="fa-solid fa-star"></i></label>

    <input type="radio" name="rate" id="star3" value="3">
    <label for="star3"><i class="fa-solid fa-star"></i></label>

    <input type="radio" name="rate" id="star2" value="2">
    <label for="star2"><i class="fa-solid fa-star"></i></label>

    <input type="radio" name="rate" id="star1" value="1">
    <label for="star1"><i class="fa-solid fa-star"></i></label>
    </div>

    <div>
        <label>Comment:</label>
        <textarea name="description" rows="10" cols="50">Escribe tu opinión...</textarea>
    </div>

     <input type="hidden" name="gameId" value=@game.Id>

    <button type="submit">Enviar</button>
</form>
}
}









<br /><br /><br /><br /><br /><br /><br /><br />

<script>
const gameId = parseInt("@game.Id");
const statusText = document.getElementById("statusText");

const interval = setInterval(async () => {
    try {
        const res = await fetch(`@Url.Action("CheckStatus", "Home")?gameId=${gameId}`);
        const status = await res.text();

        // Mostrar estado
        if (status === "Scanning") {
            statusText.innerText = "🟡 Escaneando...";
        } 
        else if (status === "Safe") {
            statusText.innerText = "🟢 Seguro";
            clearInterval(interval);
        } 
        else if (status === "Malicious") {
            statusText.innerText = "🔴 Malware detectado";
            clearInterval(interval);
        } 
        else {
            statusText.innerText = status;
        }

    } catch (err) {
        console.error(err);
        statusText.innerText = "Error al verificar";
        clearInterval(interval);
    }
}, 5000); // cada 5s

let dots = 0;

setInterval(() => {
    if (statusText.innerText.includes("Escaneando")) {
        dots = (dots + 1) % 4;
        statusText.innerText = "🟡 Escaneando" + ".".repeat(dots);
    }
}, 500);


</script>