@{
    Game game = ViewBag.gameInfo;
    var images = ViewBag.images;
    ViewData["Title"] = game.GameName;
}

<h1>@game.GameName</h1>

@if(images != null && images.Count > 0)
{
  <div style="width:600px; margin:auto;">
<div id="carouselExampleIndicators" class="carousel slide" data-bs-ride="carousel">

  <div class="carousel-inner">

    <div class="carousel-item active">
      <img class="d-block w-100" src="~/GamePictures/@images[0].image">
    </div>

    @for(int i = 1; i < images.Count; i++)
    {
        <div class="carousel-item">
            <img class="d-block w-100" src="~/GamePictures/@images[i].image">
        </div>
    }

  </div>

  <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>

  <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>

</div>
</div>
}

<p>@game.Description</p>

@if (ViewBag.isElectron)
{
    <a href='@Url.Content("~/Download/"+game.Id)'>Instalar juego</a>
}
else
{
    <button>Descargar steam2 (steam es malo)</button>
}