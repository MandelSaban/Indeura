@{
    Game game = ViewBag.gameInfo;
    var images = ViewBag.images;
    ViewData["Title"] = game.GameName;
}

@{
    var usuarioJson = Context.Session.GetString("usuario"); 
    User usuario = null;
    if (!string.IsNullOrEmpty(usuarioJson))
    {
        usuario = Objeto.StringToObject<User>(usuarioJson);
    }
}

<h1>@game.GameName</h1>   

@if(images != null && images.Count > 0)
{
  <div style="width:600px; margin:auto;">
<div id="carouselExampleIndicators" class="carousel slide" data-bs-ride="carousel">

  <div class="carousel-inner">

    <div class="carousel-item active">
      <img class="d-block w-100" src="~/GamePictures/@images[0].image">
    </div>

    @for(int i = 1; i < images.Count; i++)
    {
        <div class="carousel-item">
            <img class="d-block w-100" src="~/GamePictures/@images[i].image">
        </div>
    }

  </div>

  <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>

  <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>

</div>
</div>
}
@if(ViewBag.ImPublisher){
  <form action="@Url.Action("SubirImagenes","Home")" method="post" enctype="multipart/form-data">
    <input type="file" name="imagenes" multiple accept="image/*" />
    <button type="submit">Subir</button>
  </form>
}

<p>@game.Description</p>

<p>
    Tags:
    @foreach(var tag in ViewBag.tags)
    {
        <span>@tag </span>
    }
</p>

<p>Created by: @ViewBag.creator</p>

@if(usuario == null){
  if(game.PriceUSD == 0){
    <a href='@Url.Action("LoginRedirect", "Home", new { returnUrl = "/Home/GamePage?gameId=" + game.Id })'>Añadir a tu biblioteca</a>
  }
  else{
    <a href='@Url.Action("LoginRedirect", "Home", new { returnUrl = "/Home/GamePage?gameId=" + game.Id })'>Comprar por $@game.PriceUSD USD</a>
  }  
}
else if(!ViewBag.IsOwner)
{
  if(game.PriceUSD == 0){
    <a href='@Url.Content("~/Buy/"+game.Id)'>Añadir a tu biblioteca</a>
  }
  else{
    <a href='@Url.Content("~/Buy/"+game.Id)'>Comprar por $@game.PriceUSD USD</a>
  }  
}  
else if (ViewBag.isElectron)
{
    <a href='@Url.Content("~/Download/"+game.Id)'>Instalar juego</a>
    <button onclick="openGame('C:\\Indeura\\Games\\@game.Id\\@game.ExecutableName')">Abrir juego</button>

      <script>       
        function openGame(filePath){
            window.electronAPI.send('open-file', filePath);
        }
      </script>
}
else
{
    <a href='@Url.Content("~/Download/IndeuraSetup.exe")'>Descargar Indeura</a>
}

<br /><br /><br /><br /><br />

<h4>Reviews</h4>
@if(ViewBag.reviews.Count > 0){
  @foreach(Review review in ViewBag.reviews){
  <div style="border: 1px solid black">
    <p>@BD.getNameById(review.IdUser)</p>
    <h5>@TextMods.numberToStars(review.Rating) (@((double)(review.PlaytimeSecondsAtPublish/3600))h)</h5>
    <p>@review.Description</p>
  </div>
}
}
else{
  <h6>Aún no hay nada aquí</h6>
}

@if(usuario!=null){
@if(!BD.GetReviewed(usuario.Id,game.Id)){
  <form method="post" action="@Url.Action("Review","Home")">
  <div class="rating ">
        <input type="radio" name="rate" id="star5" value="5">
    <label for="star5"><i class="fa-solid fa-star"></i></label>

    <input type="radio" name="rate" id="star4" value="4">
    <label for="star4"><i class="fa-solid fa-star"></i></label>

    <input type="radio" name="rate" id="star3" value="3">
    <label for="star3"><i class="fa-solid fa-star"></i></label>

    <input type="radio" name="rate" id="star2" value="2">
    <label for="star2"><i class="fa-solid fa-star"></i></label>

    <input type="radio" name="rate" id="star1" value="1">
    <label for="star1"><i class="fa-solid fa-star"></i></label>
    </div>

    <div>
        <label>Comment:</label>
        <textarea name="description" rows="10" cols="50">Escribe tu opinión...</textarea>
    </div>

     <input type="hidden" name="gameId" value=@game.Id>

    <button type="submit">Enviar</button>
</form>
}
}









<br /><br /><br /><br /><br /><br /><br /><br />